{
    "rules": {
        "conversations": {
            "$conversationId": {
                "messages": {
                    ".read": "auth != null",
                    "$messageId": {
                        ".write": "auth != null",
                        ".validate": "newData.hasChildren(['text', 'senderId', 'createdAt'])"
                    }
                },
                "lastMessage": {
                    ".read": "auth != null",
                    ".write": "auth != null"
                },
                "settings": {
                    ".read": "auth != null",
                    ".write": "auth != null"
                }
            }
        },
        "status": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "typing": {
            ".read": "auth != null",
            ".write": "auth != null"
        }
    }
}